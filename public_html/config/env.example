# Environment Configuration for InfinityFree
# Copy this file to .env and update with your actual database credentials

# Database Configuration for InfinityFree
DB_HOST=sql105.infinityfree.com
DB_NAME=if0_XXXXXXX_cbt_portal
DB_USER=if0_XXXXXXX
DB_PASS=your_password_here
DB_PORT=3306

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.infinityfreeapp.com
TIMEZONE=UTC

# Security Settings
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
SESSION_LIFETIME=3600